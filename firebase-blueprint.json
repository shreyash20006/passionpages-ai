{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user account was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "A saved note or study material",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The note's unique identifier"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the note"
        },
        "title": {
          "type": "string",
          "description": "The title of the note"
        },
        "content": {
          "type": "string",
          "description": "The content of the note"
        },
        "type": {
          "type": "string",
          "enum": ["summary", "flashcards", "mindmap", "slides", "table"],
          "description": "The type of content"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the note was created"
        }
      },
      "required": ["id", "userId", "title", "content", "type", "createdAt"]
    },
    "ApiKeys": {
      "title": "ApiKeys",
      "description": "Stores user-provided API keys for AI providers",
      "type": "object",
      "properties": {
        "gemini": { "type": "string" },
        "openai": { "type": "string" },
        "anthropic": { "type": "string" },
        "deepseek": { "type": "string" },
        "groq": { "type": "string" },
        "updatedAt": { "type": "timestamp" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/users/{userId}/settings/api_keys": {
      "schema": {
        "$ref": "#/entities/ApiKeys"
      },
      "description": "Stores user-provided API keys"
    },
    "/notes/{noteId}": {
      "schema": {
        "$ref": "#/entities/Note"
      },
      "description": "Stores saved notes and study materials"
    }
  }
}
